---
import AuthLayout from "../layouts/AuthLayout.astro";
import { Icon } from "astro-icon/components";

export const prerender = false;
---

<AuthLayout title="Register">
  <div class="space-y-8">
    <!-- Logo / Header -->
    <div class="text-center">
      <div class="inline-flex items-center justify-center size-12 rounded-xl bg-ctp-mauve/10 mb-4">
        <Icon name="lucide:target" class="size-6 text-ctp-mauve" />
      </div>
      <h1 class="text-2xl font-bold text-ctp-text">Create your account</h1>
      <p class="mt-1 text-sm text-ctp-subtext0">Get started with OneThing for Teams</p>
    </div>

    <!-- Register form -->
    <form
      x-data="{ loading: false, error: '' }"
      x-on:submit.prevent="
        loading = true;
        error = '';
        const form = $el;
        const data = Object.fromEntries(new FormData(form));
        if (data.password !== data.confirmPassword) {
          error = 'Passwords do not match';
          loading = false;
          return;
        }
        fetch('/api/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: data.email,
            username: data.username,
            displayName: data.displayName,
            password: data.password,
            confirmPassword: data.confirmPassword,
            initialOrganizationName: data.organizationName,
          }),
        })
          .then(r => r.json().then(body => ({ ok: r.ok, body })))
          .then(({ ok, body }) => {
            if (ok) {
              window.location.href = '/login?registered=true';
            } else {
              error = body.error || 'Registration failed';
            }
          })
          .catch(() => { error = 'Network error'; })
          .finally(() => { loading = false; });
      "
      class="space-y-4"
    >
      <!-- Error message -->
      <div x-show="error" x-cloak class="p-3 rounded-lg bg-ctp-red/10 text-ctp-red text-sm" x-text="error"></div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label for="displayName" class="block text-sm font-medium text-ctp-subtext1 mb-1.5">Display name</label>
          <input
            type="text"
            id="displayName"
            name="displayName"
            required
            class="w-full px-3 py-2 rounded-lg border border-ctp-surface1 bg-ctp-surface0 text-ctp-text placeholder-ctp-overlay0 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:border-transparent text-sm"
            placeholder="Jane Doe"
          />
        </div>
        <div>
          <label for="username" class="block text-sm font-medium text-ctp-subtext1 mb-1.5">Username</label>
          <input
            type="text"
            id="username"
            name="username"
            required
            autocomplete="username"
            class="w-full px-3 py-2 rounded-lg border border-ctp-surface1 bg-ctp-surface0 text-ctp-text placeholder-ctp-overlay0 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:border-transparent text-sm"
            placeholder="janedoe"
          />
        </div>
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-ctp-subtext1 mb-1.5">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="w-full px-3 py-2 rounded-lg border border-ctp-surface1 bg-ctp-surface0 text-ctp-text placeholder-ctp-overlay0 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:border-transparent text-sm"
          placeholder="you@example.com"
        />
      </div>

      <div>
        <label for="organizationName" class="block text-sm font-medium text-ctp-subtext1 mb-1.5">Organization name</label>
        <input
          type="text"
          id="organizationName"
          name="organizationName"
          required
          class="w-full px-3 py-2 rounded-lg border border-ctp-surface1 bg-ctp-surface0 text-ctp-text placeholder-ctp-overlay0 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:border-transparent text-sm"
          placeholder="Acme Inc."
        />
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-ctp-subtext1 mb-1.5">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          required
          autocomplete="new-password"
          class="w-full px-3 py-2 rounded-lg border border-ctp-surface1 bg-ctp-surface0 text-ctp-text placeholder-ctp-overlay0 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:border-transparent text-sm"
          placeholder="••••••••"
        />
      </div>

      <div>
        <label for="confirmPassword" class="block text-sm font-medium text-ctp-subtext1 mb-1.5">Confirm password</label>
        <input
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          required
          autocomplete="new-password"
          class="w-full px-3 py-2 rounded-lg border border-ctp-surface1 bg-ctp-surface0 text-ctp-text placeholder-ctp-overlay0 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:border-transparent text-sm"
          placeholder="••••••••"
        />
      </div>

      <button
        type="submit"
        x-bind:disabled="loading"
        class="w-full py-2.5 rounded-lg bg-ctp-mauve text-ctp-base font-medium text-sm hover:bg-ctp-mauve/90 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:ring-offset-2 focus:ring-offset-ctp-base disabled:opacity-50 transition-colors"
      >
        <span x-show="!loading">Create account</span>
        <span x-show="loading" x-cloak>Creating account...</span>
      </button>
    </form>

    <p class="text-center text-sm text-ctp-subtext0">
      Already have an account?
      <a href="/login" class="text-ctp-mauve hover:text-ctp-mauve/80 font-medium">Sign in</a>
    </p>
  </div>
</AuthLayout>
