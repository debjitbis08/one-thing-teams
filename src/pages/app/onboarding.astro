---
import AuthLayout from "../../layouts/AuthLayout.astro";
import { Icon } from "astro-icon/components";
import { listProductsForOrg } from "../../contexts/pm/infrastructure/read/ProductReadRepository";

export const prerender = false;

if (!Astro.locals.session) {
  return Astro.redirect("/login");
}

// Already has products — skip onboarding
const products = await listProductsForOrg(Astro.locals.session.organizationId);
if (products.length > 0) {
  return Astro.redirect("/app");
}
---

<AuthLayout title="Get Started">
  <div
    x-data="{
      step: 1,
      // Step 1: Product
      productName: '',
      productLoading: false,
      productError: '',
      productCreated: false,
      // Step 2: Invitations
      inviteEmail: '',
      inviteRole: 'EDITOR',
      inviteLoading: false,
      inviteError: '',
      invitedList: [],

      async createProduct() {
        this.productLoading = true;
        this.productError = '';
        try {
          const res = await fetch('/api/products', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: this.productName }),
          });
          const body = await res.json();
          if (res.ok) {
            this.productCreated = true;
            this.step = 2;
          } else {
            this.productError = body.error || 'Failed to create product';
          }
        } catch {
          this.productError = 'Network error';
        } finally {
          this.productLoading = false;
        }
      },

      async sendInvite() {
        this.inviteLoading = true;
        this.inviteError = '';
        try {
          const res = await fetch('/api/invitations', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: this.inviteEmail, role: this.inviteRole }),
          });
          const body = await res.json();
          if (res.ok) {
            this.invitedList.push({ email: this.inviteEmail, role: this.inviteRole });
            this.inviteEmail = '';
          } else {
            this.inviteError = body.error || 'Failed to send invitation';
          }
        } catch {
          this.inviteError = 'Network error';
        } finally {
          this.inviteLoading = false;
        }
      },

      finish() {
        window.location.href = '/app';
      }
    }"
    class="space-y-8"
  >
    <!-- Header -->
    <div class="text-center">
      <div class="inline-flex items-center justify-center size-12 rounded-xl bg-ctp-mauve/10 mb-4">
        <Icon name="lucide:sparkles" class="size-6 text-ctp-mauve" />
      </div>
      <h1 class="text-2xl font-bold text-ctp-text">Let's get started</h1>
      <p class="mt-1 text-sm text-ctp-subtext0">Set up your workspace in a couple of steps</p>
    </div>

    <!-- Progress indicator -->
    <div class="flex items-center justify-center gap-2">
      <div
        class="size-2.5 rounded-full transition-colors"
        x-bind:class="step >= 1 ? 'bg-ctp-mauve' : 'bg-ctp-surface1'"
      ></div>
      <div class="w-12 h-0.5 rounded-full transition-colors"
        x-bind:class="step >= 2 ? 'bg-ctp-mauve' : 'bg-ctp-surface1'"
      ></div>
      <div
        class="size-2.5 rounded-full transition-colors"
        x-bind:class="step >= 2 ? 'bg-ctp-mauve' : 'bg-ctp-surface1'"
      ></div>
    </div>

    <!-- Step 1: Create Product -->
    <div x-show="step === 1" x-transition>
      <div class="space-y-4">
        <div>
          <h2 class="text-lg font-semibold text-ctp-text">Create your first product</h2>
          <p class="text-sm text-ctp-subtext0 mt-1">
            A product is what your team ships. Initiatives, tasks, and metrics all live under a product.
          </p>
        </div>

        <!-- Error -->
        <div x-show="productError" x-cloak class="p-3 rounded-lg bg-ctp-red/10 text-ctp-red text-sm" x-text="productError"></div>

        <div>
          <label for="productName" class="block text-sm font-medium text-ctp-subtext1 mb-1.5">Product name</label>
          <input
            type="text"
            id="productName"
            x-model="productName"
            class="w-full px-3 py-2 rounded-lg border border-ctp-surface1 bg-ctp-surface0 text-ctp-text placeholder-ctp-overlay0 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:border-transparent text-sm"
            placeholder="e.g. Mobile App, Dashboard, API Platform"
          />
        </div>

        <button
          x-on:click="createProduct()"
          x-bind:disabled="productLoading || productName.trim() === ''"
          class="w-full py-2.5 rounded-lg bg-ctp-mauve text-ctp-base font-medium text-sm hover:bg-ctp-mauve/90 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:ring-offset-2 focus:ring-offset-ctp-base disabled:opacity-50 transition-colors"
        >
          <span x-show="!productLoading">Create product</span>
          <span x-show="productLoading" x-cloak>Creating...</span>
        </button>
      </div>
    </div>

    <!-- Step 2: Invite Team -->
    <div x-show="step === 2" x-transition>
      <div class="space-y-4">
        <div>
          <h2 class="text-lg font-semibold text-ctp-text">Invite your team</h2>
          <p class="text-sm text-ctp-subtext0 mt-1">
            Add team members now or skip this step and invite them later.
          </p>
        </div>

        <!-- Error -->
        <div x-show="inviteError" x-cloak class="p-3 rounded-lg bg-ctp-red/10 text-ctp-red text-sm" x-text="inviteError"></div>

        <!-- Invited list -->
        <template x-for="inv in invitedList" x-bind:key="inv.email">
          <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-ctp-surface0 text-sm">
            <span class="text-ctp-text" x-text="inv.email"></span>
            <span class="text-xs text-ctp-subtext0 bg-ctp-surface1 px-2 py-0.5 rounded-full" x-text="inv.role"></span>
          </div>
        </template>

        <!-- Invite form -->
        <div class="flex gap-2">
          <input
            type="email"
            x-model="inviteEmail"
            class="flex-1 px-3 py-2 rounded-lg border border-ctp-surface1 bg-ctp-surface0 text-ctp-text placeholder-ctp-overlay0 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:border-transparent text-sm"
            placeholder="colleague@example.com"
          />
          <select
            x-model="inviteRole"
            class="px-3 py-2 rounded-lg border border-ctp-surface1 bg-ctp-surface0 text-ctp-text text-sm focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:border-transparent"
          >
            <option value="ADMIN">Admin</option>
            <option value="EDITOR">Editor</option>
            <option value="VIEWER">Viewer</option>
          </select>
        </div>

        <div class="flex gap-2">
          <button
            x-on:click="sendInvite()"
            x-bind:disabled="inviteLoading || inviteEmail.trim() === ''"
            class="flex-1 py-2.5 rounded-lg bg-ctp-mauve text-ctp-base font-medium text-sm hover:bg-ctp-mauve/90 focus:outline-none focus:ring-2 focus:ring-ctp-mauve focus:ring-offset-2 focus:ring-offset-ctp-base disabled:opacity-50 transition-colors"
          >
            <span x-show="!inviteLoading">Send invite</span>
            <span x-show="inviteLoading" x-cloak>Sending...</span>
          </button>
        </div>

        <!-- Actions -->
        <div class="pt-2 space-y-2">
          <button
            x-on:click="finish()"
            class="w-full py-2.5 rounded-lg font-medium text-sm transition-colors"
            x-bind:class="invitedList.length > 0
              ? 'bg-ctp-green text-ctp-base hover:bg-ctp-green/90'
              : 'border border-ctp-surface1 text-ctp-subtext1 hover:text-ctp-text hover:bg-ctp-surface0'"
          >
            <span x-text="invitedList.length > 0 ? 'Continue to dashboard' : 'Skip for now'"></span>
          </button>
        </div>
      </div>
    </div>
  </div>
</AuthLayout>
