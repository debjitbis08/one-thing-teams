---
import AppLayout from "../../layouts/AppLayout.astro";
import { listProductsForOrg } from "../../contexts/pm/infrastructure/read/ProductReadRepository";

export const prerender = false;

if (!Astro.locals.session) {
  return Astro.redirect("/login");
}

const products = await listProductsForOrg(Astro.locals.session.organizationId);

if (products.length === 0) {
  return Astro.redirect("/app/onboarding");
}
---

<AppLayout title="Dashboard">
  <div>
    <h1 class="text-xl font-bold text-ctp-text">Dashboard</h1>
    <p class="mt-2 text-ctp-subtext0">Welcome to OneThing for Teams.</p>
  </div>
</AppLayout>
